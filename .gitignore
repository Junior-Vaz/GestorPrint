build/
.next/
out/
backend/dist/
backend/manual_dist/
backend/temp_dist/
frontend/dist/
saas-admin/dist/

# TypeScript incremental cache
*.tsbuildinfo

# Variáveis sensíveis (NUNCA commitar)
.env
.env.local
.env.*.local
ai-error-dump.log
error.log

# OS metadata
.DS_Store
Thumbs.db

