# ════════════════════════════════════════════════════════════════════════════
#  GestorPrint — Variáveis de ambiente (PRODUÇÃO)
# ════════════════════════════════════════════════════════════════════════════
# Copie esse arquivo para `.env` (raiz do repositório, lido pelo docker-compose)
# e preencha os valores reais.
#
# Filosofia: env só pra coisas que o BOOT precisa antes do banco subir.
# Tudo que é configurável depois fica em UI:
#
#   • SaaS Admin → Configurações da Plataforma
#       Asaas (cobrança SaaS), SMTP global, API URL pública
#   • ERP → Configurações (per-tenant)
#       Mercado Pago, Melhor Envios, SMTP do tenant, businessHours
#   • ERP → IA (per-tenant)
#       Gemini/OpenAI/Anthropic, Evolution/WhatsApp

# ─── 1. AMBIENTE ───────────────────────────────────────────────────────────
NODE_ENV=production

# ─── 2. BANCO DE DADOS [OBRIGATÓRIAS] ──────────────────────────────────────
# Usadas pelo docker-compose pra subir o Postgres.
POSTGRES_USER=gestorprint_admin
POSTGRES_PASSWORD=
POSTGRES_DB=gestorprint_db
# Ports — opcionais (defaults: 127.0.0.1:5432 dentro da rede docker)
# POSTGRES_BIND_IP=127.0.0.1
# POSTGRES_PORT=5432

# ─── 3. SEGURANÇA [OBRIGATÓRIAS — app NÃO sobe sem] ────────────────────────
# JWT secret — assina todos os tokens (operadores + clientes finais).
# REGRA: ≥ 32 caracteres aleatórios. Gere com:  openssl rand -hex 32
# Sem isso, o boot em produção falha com erro claro.
JWT_SECRET=

# Master key pra criptografia em repouso (AES-256-GCM) das credenciais
# sensíveis salvas no banco: geminiKey, evolutionKey, etc.
# REGRA: ≥ 32 caracteres aleatórios. Gere com:  openssl rand -hex 32
# Aceita também o nome legacy CRED_ENCRYPTION_KEY.
ENCRYPTION_KEY=

# CSV de origens HTTPS permitidas pelo CORS. Sem isso o boot em prod falha.
# Inclua TODAS as URLs públicas do ERP, SaaS Admin e Storefront.
ALLOWED_ORIGINS=https://app.gestorprint.com.br,https://admin.gestorprint.com.br,https://loja.gestorprint.com.br

# ─── 4. URLs PÚBLICAS [OBRIGATÓRIA] ────────────────────────────────────────
# Usada pra montar webhook URLs (Evolution, Mercado Pago) e links públicos
# de PDF/aprovação. Tem fallback no PlatformSettings.apiUrl mas é mais simples
# definir aqui.
API_URL=https://api.gestorprint.com.br

# ─── 5. PORTS [OPCIONAIS] ──────────────────────────────────────────────────
# Backend interno é sempre 3000. BACKEND_PORT é a porta exposta na host.
# BACKEND_PORT=3000
# FRONTEND_PORT=80
# SAAS_ADMIN_PORT=5174

# Opcional: 'false' desliga o redirect HTTPS interno (use só se reverse proxy
# nginx/cloudflare já cuida do redirect)
# FORCE_HTTPS=true

# ─── 6. WEBHOOK TOKENS [OPCIONAIS — recomendados] ──────────────────────────
# Token opcional que o webhook do WhatsApp (Evolution → /api/whatsapp/webhook)
# espera no header. Aceita também WEBHOOK_TOKEN como nome legacy.
# Se vazio, qualquer um pode chamar o webhook.
WHATSAPP_WEBHOOK_TOKEN=

# ─── 7. STORAGE [OPCIONAL] ─────────────────────────────────────────────────
# Default: disco local em ./uploads. Pra MinIO/S3, descomentar:
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=
# MINIO_BUCKET=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=

# ─── 8. SWAGGER em produção [OPCIONAL] ─────────────────────────────────────
# Por default, /api/docs fica DESABILITADO em prod. Pra ligar:
# SWAGGER_ENABLED=true
# SWAGGER_USER=gpadmin
# SWAGGER_PASS=             # gerar com: openssl rand -base64 24

# ─── 9. SUPER ADMIN INICIAL [bootstrap automático no 1º boot] ─────────────
# Lidos pelo backend em DOIS lugares:
#   • `prisma/seed.ts` (rodado manualmente via `npm run db:seed`)
#   • `auth.service.onModuleInit` (TODO boot do backend, idempotente)
# Em fresh install (sem nenhum PLATFORM user no banco), o backend cria o admin
# inicial usando essas vars. Em instalações que já têm PLATFORM users, é no-op.
#
# IMPORTANTE: senha NÃO aparece no log em produção (NODE_ENV=production esconde).
# Em dev mostra pra DX. Ideal é definir um valor temporário aqui, fazer login
# uma vez, trocar via SaaS Admin → Equipe → editar, e depois pode até remover
# essas vars do .env (PLATFORM users já criados continuam funcionando).
SUPER_ADMIN_EMAIL=admin@gestorprint.com.br
SUPER_ADMIN_PASSWORD=TROCAR_NO_PRIMEIRO_LOGIN
SUPER_ADMIN_NAME=Administrador da Plataforma

# ─── 10. FRONTEND build args ───────────────────────────────────────────────
# Bake-in no Docker build do frontend e saas-admin.
VITE_API_URL=https://api.gestorprint.com.br


# ════════════════════════════════════════════════════════════════════════════
#  NÃO vai aqui — configurado via UI:
#
#  SaaS Admin Panel  →  Configurações da Plataforma:
#    • Asaas         (asaasApiKey, asaasEnv, asaasWebhookToken, gracePeriodDays)
#    • SMTP global   (smtpHost, smtpPort, smtpUser, smtpPass, smtpFrom)
#                    Emails de trial vencendo, fatura, etc.
#
#  ERP do tenant  →  Configurações  (cada gráfica configura a sua):
#    • Mercado Pago  (mpAccessToken, mpPublicKey, mpWebhookSecret)
#    • Melhor Envios (meAccessToken, originCep, etc.)
#    • Gemini / OpenAI / Anthropic (geminiKey, modelo)
#    • Evolution API (evolutionUrl, evolutionKey, evolutionInstance)
#    • SMTP do tenant (Settings.smtpHost — distinto do SMTP global)
#    • Métodos de pagamento aceitos, businessHours, paymentMethods
# ════════════════════════════════════════════════════════════════════════════
