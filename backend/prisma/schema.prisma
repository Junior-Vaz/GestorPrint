generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT (SaaS Multi-Tenant) ─────────────────────────────────────────────
model Tenant {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  // Plano & Assinatura
  plan            String    @default("FREE")        // FREE, BASIC, PRO, ENTERPRISE
  planStatus      String    @default("TRIAL")       // TRIAL, ACTIVE, SUSPENDED, CANCELLED
  trialEndsAt     DateTime?
  planExpiresAt   DateTime?
  maxUsers        Int       @default(3)             // limite de usuários por plano
  maxOrders       Int       @default(100)           // limite de pedidos/mês por plano
  maxCustomers    Int       @default(50)            // limite de clientes cadastrados
  // Contato do responsável
  ownerName       String?
  ownerEmail      String?
  ownerPhone      String?
  cpfCnpj         String?   // CPF (11 dígitos) ou CNPJ (14 dígitos) — obrigatório para Asaas
  // Asaas (gateway de cobrança SaaS)
  asaasCustomerId     String?   // cus_000005113654
  asaasSubscriptionId String?   // sub_000000123456
  // Estado
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  // Relacionamentos
  customers         Customer[]
  productTypes      ProductType[]
  products          Product[]
  estimates         Estimate[]
  orders            Order[]
  users             User[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  suppliers         Supplier[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  settings          Settings[]
  aiConfigs         AiConfig[]
}

model Customer {
  id        Int        @id @default(autoincrement())
  tenantId  Int        @default(1)
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  phone     String?
  document  String?
  zipCode      String?
  address      String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  orders    Order[]
  estimates Estimate[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([email, tenantId])
  @@unique([document, tenantId])
}

model ProductType {
  id        Int       @id @default(autoincrement())
  tenantId  Int       @default(1)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  color     String    @default("#6366f1")
  hasStock  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([name, tenantId])
}

model Product {
  id          Int             @id @default(autoincrement())
  tenantId    Int             @default(1)
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  name        String
  productType ProductType     @relation(fields: [typeId], references: [id])
  typeId      Int
  unit        String          @default("un") // m², kg, un, h
  unitPrice   Float
  brand       String?
  markup      Float           @default(0) // percentage markup
  stock       Float           @default(0)
  minStock    Float           @default(0)
  description String?
  supplierId  Int?
  supplier    Supplier?       @relation(fields: [supplierId], references: [id])
  movements   StockMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  quantity  Float // positive for entry, negative for exit
  type      String // PURCHASE, SALE (PRODUCTION), ADJUSTMENT
  reason    String?
  createdAt DateTime @default(now())
}

model Estimate {
  id         Int      @id @default(autoincrement())
  tenantId   Int      @default(1)
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId Int
  status     String   @default("DRAFT") // DRAFT, SENT, APPROVED, REJECTED
  details    Json // Contains dynamic calculator fields like width, height, colors, etc.
  totalPrice Float
  orders     Order[] // An estimate can generate one or more production orders

  // Employee Assignment
  salespersonId Int?
  salesperson   User? @relation("EstimateSalesperson", fields: [salespersonId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                 Int       @id @default(autoincrement())
  tenantId           Int       @default(1)
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId         Int
  estimate           Estimate? @relation(fields: [estimateId], references: [id])
  estimateId         Int?
  productDescription String // Snapshot of what to produce
  amount             Float
  status             String    @default("PENDING") // PENDING, PRODUCTION, FINISHED, DELIVERED
  details            Json? // Stores items for PDV orders
  // Employee Assignment
  salespersonId      Int?
  salesperson        User?     @relation("Salesperson", fields: [salespersonId], references: [id])
  producerId         Int?
  producer           User?     @relation("Producer", fields: [producerId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  attachments  Attachment[]
}

model Attachment {
  id           Int      @id @default(autoincrement())
  filename     String   @unique
  originalName String
  mimetype     String
  size         Int
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      Int
  createdAt    DateTime @default(now())
}

model Settings {
  id            Int      @id @default(autoincrement())
  tenantId      Int      @unique @default(1)
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  companyName   String   @default("Minha Gráfica")
  cnpj          String?
  phone         String?
  email         String?
  address       String?
  smtpHost      String?
  smtpPort      Int?     @default(587)
  smtpUser      String?
  smtpPass      String?
  smtpSecure    Boolean  @default(false)
  mpAccessToken String?
  mpPublicKey   String?
  logoUrl       String?
  updatedAt     DateTime @updatedAt
}

model User {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  email    String
  password String
  name     String
  role     String @default("ADMIN") // ADMIN, SALES, PRODUCTION

  // Employee Details
  phone          String?
  document       String?
  salary         Float?
  commissionRate Float?  @default(0)
  isActive       Boolean @default(true)

  // Relationships
  salesOrders    Order[]    @relation("Salesperson")
  producedOrders Order[]    @relation("Producer")
  salesEstimates Estimate[] @relation("EstimateSalesperson")

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  AuditLog  AuditLog[]

  @@unique([email, tenantId])
}

model Transaction {
  id           Int      @id @default(autoincrement())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      Int
  amount       Float
  status       String   @default("PENDING") // PENDING, PAID, CANCELLED, REFUNDED
  paymentType  String   @default("PIX") // PIX, CREDIT_CARD, CASH
  gatewayId    String?  @unique // Reference from Mercado Pago
  paymentUrl   String? // Link for payment or QR code data
  qrCode       String? // Pix "Copia e Cola" string
  qrCodeBase64 String? // Pix QR Code image (base64)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id          Int       @id @default(autoincrement())
  tenantId    Int       @default(1)
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  description String
  amount      Float
  category    String
  date        DateTime  @default(now())
  supplierId  Int?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ExpenseCategory {
  id       Int    @id @default(autoincrement())
  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  name     String

  @@unique([name, tenantId])
}

model Supplier {
  id        Int       @id @default(autoincrement())
  tenantId  Int       @default(1)
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  phone     String?
  category  String?
  address   String?
  expenses  Expense[]
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ALERTA
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AiConfig {
  id                  Int      @id @default(autoincrement())
  tenantId            Int      @unique @default(1)
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  enabled             Boolean  @default(false)
  geminiKey           String?
  geminiModel         String?  @default("gemini-2.0-flash")
  maxTokens           Int?     @default(1000)
  evolutionUrl        String?  @default("https://api.cslsoftwares.com.br")
  evolutionKey        String?
  evolutionInstance   String?  @default("gestorprint")
  agentPrompt         String?  @default("Você é um atendente inteligente da nossa gráfica...")
  allowedProductTypes Int[]    @default([])
  allowFileUploads    Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

// ─── PLAN CONFIG (SaaS Plan Management) ─────────────────────────────────────
model PlanConfig {
  id          Int      @id @default(autoincrement())
  name        String   @unique   // "FREE", "BASIC", "PRO", "ENTERPRISE" ou custom
  displayName String             // "Gratuito", "Básico", etc.
  description String?

  // ── Limites numéricos ──────────────────────────────────────────────────────
  price        Float   @default(0)     // R$/mês cobrado no Asaas
  maxUsers     Int     @default(1)     // usuários simultâneos
  maxOrders    Int     @default(30)    // pedidos por mês
  maxCustomers Int     @default(50)    // clientes cadastrados

  // ── Módulos Operacionais ──────────────────────────────────────────────────
  hasPdf        Boolean @default(false) // PDF de orçamentos e pedidos
  hasReports    Boolean @default(false) // Relatórios financeiros + exportar CSV
  hasKanban     Boolean @default(false) // Fila de produção (board Kanban)
  hasFileUpload Boolean @default(false) // Upload arquivos gráficos (.cdr, .psd, .svg...)

  // ── Integrações ───────────────────────────────────────────────────────────
  hasWhatsapp Boolean @default(false)  // WhatsApp AI (Gemini + Evolution API)
  hasPix      Boolean @default(false)  // PIX via Mercado Pago

  // ── Gestão Avançada ───────────────────────────────────────────────────────
  hasAudit       Boolean @default(false) // Auditoria completa de ações
  hasCommissions Boolean @default(false) // Comissões por vendedor
  hasApiAccess   Boolean @default(false) // Webhooks / acesso externo

  // ── Meta ─────────────────────────────────────────────────────────────────
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  tenantId  Int      @default(1)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String // CREATE, UPDATE, DELETE
  entity    String // Order, Product, User, Estimate, etc.
  entityId  Int? // ID of the entity that was affected
  details   Json? // Optional JSON containing old/new values or specific change notes
  createdAt DateTime @default(now())
}
