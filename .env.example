# ============================================================
# GestorPrint ERP — Environment Variables
# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=gestorprint_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gestorprint_db
POSTGRES_PORT=5432

# ── Backend NestJS ──────────────────────────────────────────
BACKEND_PORT=3000
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_HERE

# ── Mercado Pago ────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Frontend Vue.js ─────────────────────────────────────────
# URL pública da sua API (domínio ou IP do servidor)
VITE_API_URL=http://SEU_DOMINIO_OU_IP:3000
FRONTEND_PORT=80

# ── WhatsApp AI Agent ───────────────────────────────────────
WHATSAPP_AI_PORT=3005
# Nota: Gemini Key e Evolution config são gerenciados pelo
# Dashboard do ERP em: Configurações > Agente de IA
